{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-atomization-queue",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/track-distribution-metrics",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/publish-atomic-content",
      "schedule": "0 12 * * *"
    }
  ]
}
