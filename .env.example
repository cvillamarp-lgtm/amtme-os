# ── Frontend — Desarrollo local (.env.local) ──────────────────────────────────
VITE_SUPABASE_URL=https://tu-project-id.supabase.co
# Usa UNA de estas dos (mismo valor anon key):
VITE_SUPABASE_ANON_KEY=tu-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=tu-anon-key
VITE_SUPABASE_PROJECT_ID=tu-project-id

# ── Vercel Secrets (Producción) ───────────────────────────────────────────────
# Configurar en: Vercel Dashboard > Project > Settings > Environment Variables
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon-key>
# VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>
# VITE_SUPABASE_PROJECT_ID=<project-id>

# ── Edge Functions (Supabase Dashboard > Settings > Edge Functions > Secrets) ─
# Auto-inyectadas por Supabase — NO configurar manualmente:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# ── IA — al menos UNA requerida (Supabase Secrets) ───────────────────────────
# GEMINI_API_KEY: GRATIS en aistudio.google.com/apikey — REQUERIDO para imágenes ⭐
# GEMINI_API_KEY=AIza...

# OPENAI_API_KEY: PAGO — fallback imágenes (DALL-E 3) y texto
# OPENAI_API_KEY=sk-...

# GROQ_API_KEY: texto rápido (guiones, captions) — gratuito con límites
# GROQ_API_KEY=gsk_...

# GROK_API_KEY: PAGO — Grok (X.ai) — fallback primario para texto (rápido y económico)
# GROK_API_KEY=xai-...

# LOVABLE_API_KEY: gateway IA alternativo — auto-inyectado en Lovable Cloud
# (no configurar manualmente salvo despliegue fuera de Lovable)

# ANTHROPIC_API_KEY: PAGO — Claude Sonnet (REQUERIDO para Script Engine/pipeline editorial) ⭐
# ANTHROPIC_API_KEY=sk-ant-...
