#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Type check
echo "📝 Checking TypeScript..."
npm run type-check || exit 1

# ESLint
echo "🎯 Running ESLint..."
npm run lint || exit 1

# Build check
echo "🏗️  Building project..."
npm run build || exit 1

echo "✅ All checks passed!"
